{
	"i18n": true,
	"type": "panel",
	"items": {
		"authHeader": {
			"type": "header",
			"text": "authHeader",
			"size": 2,
			"newLine": true,
			"xs": 12
		},
		"authStatus": {
			"type": "textSendTo",
			"label": "authStatus",
			"command": "getAuthStatus",
			"newLine": true,
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 4,
			"xl": 4
		},
		"_oauthStart": {
			"type": "sendTo",
			"label": "authenticateWithBluetti",
			"command": "getOAuthStartLink",
			"icon": "auth",
			"variant": "contained",
			"openUrl": true,
			"showProcess": true,
			"timeout": 15000,
			"jsonData": "{\"adminOrigin\":\"${data._origin}\"}",
			"newLine": true,
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 4,
			"xl": 4
		},
		"_deviceSelectionHint": {
			"type": "staticText",
			"text": "deviceSelectionHint",
			"hidden": "data.authStatus === 'authenticated'",
			"newLine": true,
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 4,
			"xl": 4
		},
		"deviceSerial": {
			"type": "selectSendTo",
			"label": "deviceSelection",
			"help": "deviceSelectionHelp",
			"command": "getDevices",
			"jsonData": "{}",
			"hidden": "data.authStatus !== 'authenticated'",
			"alsoDependsOn": ["authStatus"],
			"newLine": true,
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 4,
			"xl": 4
		},
		"pollInterval": {
			"type": "number",
			"label": "pollInterval",
			"help": "pollIntervalHelp",
			"min": 60,
			"max": 86400,
			"newLine": true,
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 4,
			"xl": 4
		}
	}
}
